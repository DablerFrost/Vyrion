<style>

/* ── THEME ──────────────────────────────────────────────── */
:root{
  --void:#020912;--void2:#061624;--void3:#0b2035;
  --glow:#00D4FF;--amber:#FFB84D;--breach:#F03030;--warn:#F09000;
  --t1:#e4f2ff;--t2:#6a9ab8;--t3:#2d6080;
  --border:rgba(0,212,255,.12);--border2:rgba(0,212,255,.07);
  --nav-bg:rgba(2,9,18,.97);
  --scanline:rgba(0,212,255,.004);
}
[data-theme="light"]{
  --void:#f0f5ff;--void2:#e4eeff;--void3:#d5e5ff;
  --glow:#0066CC;--amber:#b07800;--breach:#b82020;--warn:#a05800;
  --t1:#060e1e;--t2:#1e4a7a;--t3:#3a6090;
  --border:rgba(0,102,204,.18);--border2:rgba(0,102,204,.10);
  --nav-bg:rgba(240,245,255,.98);
  --scanline:transparent;
}

/* ── RESET ──────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:18px}
body{
  background:var(--void);color:var(--t1);
  font-family:'Archivo',sans-serif;font-size:1rem;
  line-height:1.65;min-height:100vh;overflow-x:hidden;
  transition:background .3s,color .3s;
}
body::after{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:990;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,
    var(--scanline) 3px,var(--scanline) 4px);
}

/* ── NAV ────────────────────────────────────────────────── */
.nav{
  position:sticky;top:0;z-index:500;height:52px;
  display:flex;align-items:center;gap:1rem;padding:0 1.8rem;
  background:var(--nav-bg);border-bottom:1px solid var(--border);
  backdrop-filter:blur(20px);
}
.nav-logo{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;font-size:.95rem;
  color:var(--glow);letter-spacing:.15em;text-decoration:none;flex-shrink:0;
  text-shadow:0 0 20px rgba(0,212,255,.3);
}
.nav-links{display:flex;gap:1.8rem;list-style:none;flex:1}
.nav-links a{
  font-family:'Archivo Narrow',sans-serif;font-weight:700;font-size:.65rem;
  letter-spacing:.16em;text-transform:uppercase;
  color:var(--t2);text-decoration:none;transition:color .2s;padding-bottom:2px;
}
.nav-links a:hover{color:var(--t1)}
.nav-links a.active{color:var(--glow);border-bottom:1px solid rgba(0,212,255,.4)}
.nav-controls{display:flex;align-items:center;gap:.35rem;flex-shrink:0}
.nc-sep{width:1px;height:16px;background:var(--border);margin:0 .15rem}
.nc-theme{
  font-family:'Courier Prime',monospace;font-size:.58rem;font-weight:700;
  letter-spacing:.12em;padding:.22rem .5rem;border-radius:2px;
  border:1px solid var(--border);background:transparent;
  color:var(--t2);cursor:pointer;transition:all .2s;white-space:nowrap;
}
.nc-theme:hover,.nc-theme.active{
  border-color:var(--glow);color:var(--glow);
  background:rgba(0,212,255,.08);box-shadow:0 0 8px rgba(0,212,255,.12);
}
.nc-sz{
  font-family:'Courier Prime',monospace;font-size:.6rem;font-weight:700;
  width:26px;height:26px;display:flex;align-items:center;justify-content:center;
  border-radius:2px;border:1px solid var(--border);
  background:transparent;color:var(--t3);cursor:pointer;transition:all .2s;
}
.nc-sz:hover{border-color:rgba(0,212,255,.4);color:var(--t1)}
.nc-sz.active{
  background:rgba(0,212,255,.15);border-color:var(--glow);color:var(--glow);
  box-shadow:0 0 8px rgba(0,212,255,.2);
}
.nav-dot{
  width:6px;height:6px;background:var(--glow);
  border-radius:50%;flex-shrink:0;animation:nav-pulse 2.2s infinite;
}
@keyframes nav-pulse{
  0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,212,255,.5)}
  50%{opacity:.4;box-shadow:0 0 0 7px rgba(0,212,255,0)}
}
@media(max-width:720px){
  .nav{padding:0 .9rem;gap:.5rem;height:48px}
  .nav-logo{font-size:.8rem}
  .nav-links{display:none}
  .nav-controls{gap:.22rem}
  .nc-sep{display:none}
  .nc-sz{width:22px;height:22px;font-size:.52rem}
  .nc-theme{font-size:.52rem;padding:.16rem .32rem}
}
@media(max-width:400px){
  .nav-logo{font-size:.75rem}
  .nc-sz{display:none}
}

/* ── PAGE HEADER ─────────────────────────────────────────── */
.page-header{
  padding:3.5rem 2rem 2.8rem;border-bottom:1px solid var(--border);
  position:relative;overflow:hidden;
  background-image:url('https://okay-gold-oof5kipmvh.edgeone.app/Testing%20The%20Surface%20-%20Imgur.png');
  background-size:cover;background-position:center 38%;
}
  {
  padding:3.5rem 2rem 2.8rem;
  border-bottom:1px solid var(--border);
  position:relative;overflow:hidden;
}
.page-header::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse 55% 80% at 80% 50%,
    rgba(0,212,255,.04) 0%,transparent 70%);
  pointer-events:none;
}
.page-header::after{
  content:'ARCHIVE';
  position:absolute;right:-1rem;top:50%;transform:translateY(-50%);
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:clamp(5rem,14vw,10rem);
  color:rgba(0,212,255,.025);pointer-events:none;user-select:none;
  letter-spacing:.04em;line-height:1;white-space:nowrap;
}
.page-header>*{position:relative;z-index:2}
.eyebrow{
  font-family:'Courier Prime',monospace;font-size:.65rem;color:var(--glow);
  letter-spacing:.24em;text-transform:uppercase;margin-bottom:.55rem;
  display:flex;align-items:center;gap:.55rem;
}
.eyebrow::before{content:'';width:18px;height:1px;background:var(--glow);opacity:.5}
.page-title{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:clamp(2.6rem,6vw,4.2rem);color:var(--t1);
  line-height:.95;letter-spacing:-.02em;margin-bottom:.7rem;
}
.page-sub{font-size:.84rem;color:var(--t2);max-width:60ch;line-height:1.75}

/* ── STATS STRIP ─────────────────────────────────────────── */
.stats-strip{
  display:flex;flex-wrap:wrap;
  background:var(--void2);border-bottom:1px solid var(--border);
}
.stat-cell{
  flex:1;min-width:120px;padding:.85rem 1.6rem;
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;gap:.14rem;
}
.stat-cell:last-child{border-right:none}
.stat-lbl{
  font-family:'Courier Prime',monospace;font-size:.56rem;
  color:var(--t3);letter-spacing:.18em;text-transform:uppercase;
  display:flex;align-items:center;gap:.35rem;
}
.stat-dot{
  width:4px;height:4px;background:var(--glow);
  border-radius:50%;animation:nav-pulse 2.2s infinite;flex-shrink:0;
}
.stat-val{
  font-family:'Courier Prime',monospace;font-weight:700;
  font-size:1.1rem;color:var(--glow);line-height:1;
}
.stat-val.amber{color:var(--amber)}
.stat-sub{font-family:'Courier Prime',monospace;font-size:.54rem;color:var(--t3)}

/* ── SECTION LABELS ──────────────────────────────────────── */
.section-wrap{padding:2.4rem 2rem}
.section-wrap+.section-wrap{padding-top:0}
.section-label{
  font-family:'Courier Prime',monospace;font-size:.62rem;
  color:var(--t3);letter-spacing:.18em;text-transform:uppercase;
  margin-bottom:1.4rem;display:flex;align-items:center;gap:.7rem;
}
.section-label::after{content:'';flex:1;height:1px;background:var(--border)}
.section-divider{
  height:1px;background:var(--border);margin:0 2rem;
}

/* ── INDEX SCORE TABLE ───────────────────────────────────── */
.score-table{
  width:100%;border-collapse:collapse;
  font-family:'Courier Prime',monospace;font-size:.68rem;
}
.score-table thead th{
  text-align:left;padding:.5rem .9rem .5rem 0;
  color:var(--t3);letter-spacing:.1em;text-transform:uppercase;
  border-bottom:1px solid var(--border);font-weight:400;
  font-size:.58rem;
}
.score-table thead th:first-child{padding-left:.5rem}
.score-table thead th:last-child{text-align:right}
.score-table tbody tr{
  border-bottom:1px solid var(--border2);
  transition:background .14s;
}
.score-table tbody tr:hover{background:var(--void2)}
.score-table tbody td{
  padding:.48rem .9rem .48rem 0;
  vertical-align:middle;
}
.score-table tbody td:first-child{padding-left:.5rem}
.score-table tbody td:last-child{text-align:right}
.td-day{color:var(--t3);font-size:.6rem}
.td-date{color:var(--t2)}
.td-score{color:var(--amber);font-weight:700;font-size:.78rem}
.td-delta{font-size:.64rem}
.td-delta.neg{color:var(--breach)}
.td-delta.pos{color:var(--glow)}
.td-delta.zero{color:var(--t3)}
.td-note{color:var(--t3);font-size:.58rem;max-width:36ch;
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.td-correction{
  display:inline-block;font-size:.48rem;letter-spacing:.1em;
  background:rgba(240,144,0,.08);color:var(--warn);
  border:1px solid rgba(240,144,0,.25);padding:.04rem .28rem;
  border-radius:2px;margin-left:.3rem;vertical-align:middle;
}
.td-record{
  display:inline-block;font-size:.48rem;letter-spacing:.1em;
  background:rgba(0,212,255,.07);color:var(--glow);
  border:1px solid rgba(0,212,255,.22);padding:.04rem .28rem;
  border-radius:2px;margin-left:.3rem;vertical-align:middle;
}

/* ── RECORD CARDS ────────────────────────────────────────── */
.record-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(min(100%,440px),1fr));
  gap:1px;background:var(--border);
}
.record-card{
  background:var(--void2);padding:1.4rem 1.5rem 1.2rem;
  position:relative;overflow:hidden;
  text-decoration:none;color:inherit;
  transition:background .2s;
  display:flex;flex-direction:column;
}
.record-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--breach);opacity:.7;
}
.record-card:hover{background:var(--void3)}
.rc-watermark{
  position:absolute;right:1rem;bottom:.4rem;
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:4.5rem;color:rgba(240,48,48,.04);
  pointer-events:none;user-select:none;line-height:1;
}
.rc-num{
  font-family:'Courier Prime',monospace;font-size:.56rem;
  color:var(--t3);letter-spacing:.14em;margin-bottom:.3rem;
}
.rc-company{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:1.32rem;color:var(--t1);line-height:1;
  letter-spacing:.02em;margin-bottom:.14rem;
}
.rc-meta{
  font-family:'Courier Prime',monospace;font-size:.56rem;
  color:var(--t3);margin-bottom:.7rem;
}
.rc-score-row{
  display:flex;align-items:center;gap:.7rem;margin-bottom:.65rem;
}
.rc-score{
  font-family:'Courier Prime',monospace;font-weight:700;
  font-size:1.5rem;color:var(--breach);line-height:1;
}
.rc-band{
  font-family:'Courier Prime',monospace;font-size:.52rem;
  letter-spacing:.14em;text-transform:uppercase;
  background:rgba(240,48,48,.07);color:var(--breach);
  border:1px solid rgba(240,48,48,.25);
  padding:.08rem .38rem;border-radius:2px;
}
.rc-summary{
  font-size:.74rem;color:var(--t2);line-height:1.65;
  margin-bottom:.9rem;flex:1;
}
.rc-footer{
  display:flex;align-items:center;justify-content:space-between;
  padding-top:.7rem;border-top:1px solid var(--border2);
  flex-wrap:wrap;gap:.4rem;
}
.rc-date{font-family:'Courier Prime',monospace;font-size:.58rem;color:var(--t3)}
.rc-link{
  font-family:'Courier Prime',monospace;font-size:.58rem;font-weight:700;
  letter-spacing:.1em;text-transform:uppercase;color:var(--breach);
  text-decoration:none;transition:opacity .2s;
}
.rc-link:hover{opacity:.7}

/* ── PRIOR ART BLOCK ─────────────────────────────────────── */
.prior-art{
  border-top:1px solid var(--border);
  background:var(--void2);
  padding:2rem;
}
.pa-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(min(100%,260px),1fr));
  gap:1px;background:var(--border);
  margin-top:1.4rem;
}
.pa-cell{
  background:var(--void);padding:1.1rem 1.2rem;
  display:flex;flex-direction:column;gap:.22rem;
}
.pa-lbl{
  font-family:'Courier Prime',monospace;font-size:.55rem;
  color:var(--t3);letter-spacing:.16em;text-transform:uppercase;
}
.pa-val{
  font-family:'Courier Prime',monospace;font-size:.78rem;
  color:var(--t1);line-height:1.5;
}
.pa-val a{color:rgba(0,212,255,.45);text-decoration:none}
.pa-val a:hover{color:var(--glow)}

/* ── OPEN PROOF BLOCK ────────────────────────────────────── */
.proof-block{
  border-top:1px solid var(--border);
  padding:2rem;
  display:flex;align-items:flex-start;gap:2.5rem;
  flex-wrap:wrap;
}
.pb-quote{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:clamp(1.2rem,2.5vw,1.65rem);color:var(--t2);
  line-height:1.2;letter-spacing:-.01em;flex:1;min-width:240px;
}
.pb-body{
  flex:2;min-width:240px;font-size:.76rem;
  color:var(--t2);line-height:1.72;
}
.pb-body a{color:rgba(0,212,255,.45);text-decoration:none}
.pb-body a:hover{color:var(--glow)}

/* ── FOOTER ──────────────────────────────────────────────── */
.footer{
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:1rem;padding:1.4rem 2rem;
  border-top:1px solid var(--border);
}
.footer-l{
  font-family:'Courier Prime',monospace;font-size:.6rem;
  color:var(--t3);line-height:1.75;
}
.footer-l a{color:rgba(0,212,255,.4);text-decoration:none;transition:color .18s}
.footer-l a:hover{color:var(--glow)}
.footer-r{display:flex;gap:1.4rem}
.footer-r a{
  font-family:'Courier Prime',monospace;font-size:.6rem;
  color:rgba(0,212,255,.3);text-decoration:none;transition:color .18s;
}
.footer-r a:hover{color:var(--glow)}

@media(max-width:720px){
  .section-wrap{padding:1.6rem .9rem}
  .proof-block{padding:1.4rem .9rem;flex-direction:column;gap:1rem}
  .prior-art{padding:1.4rem .9rem}
  .footer{padding:1.2rem .9rem}
  .score-table{font-size:.6rem}
  .td-note{display:none}
}
</style>
</head>
