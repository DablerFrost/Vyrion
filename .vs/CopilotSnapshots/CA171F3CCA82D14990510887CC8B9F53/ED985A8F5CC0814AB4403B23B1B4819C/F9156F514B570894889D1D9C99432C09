<script>
'use strict';

// ── THEME ─────────────────────────────────────────────────
function toggleTheme(){
  const html=document.documentElement;
  const isLight=html.getAttribute('data-theme')==='light';
  html.setAttribute('data-theme',isLight?'dark':'light');
  const btn=document.getElementById('theme-btn');
  btn.textContent=isLight?'◐ DARK':'◑ LIGHT';
  try{localStorage.setItem('vc-theme',isLight?'dark':'light')}catch(e){}
}
(function(){
  try{
    const t=localStorage.getItem('vc-theme');
    if(t==='light'){
      document.documentElement.setAttribute('data-theme','light');
      const btn=document.getElementById('theme-btn');
      if(btn)btn.textContent='◑ LIGHT';
    }
  }catch(e){}
})();

// ── FONT SCALE ────────────────────────────────────────────
const _SCALES={'0.88':16,'1.0':18,'1.22':22};
function setScale(btn){
  const px=_SCALES[btn.dataset.scale]||18;
  document.documentElement.style.fontSize=px+'px';
  document.querySelectorAll('.nc-sz').forEach(b=>
    b.classList.toggle('active',b===btn)
  );
  try{localStorage.setItem('vc-scale',btn.dataset.scale)}catch(e){}
}
(function(){
  try{
    const s=localStorage.getItem('vc-scale');
    if(s&&_SCALES[s]){
      document.documentElement.style.fontSize=_SCALES[s]+'px';
      requestAnimationFrame(()=>{
        document.querySelectorAll('.nc-sz').forEach(b=>
          b.classList.toggle('active',b.dataset.scale===s)
        );
      });
    }
  }catch(e){}
})();
</script>
