  if (e.key === 'Escape') oWelcomeDismiss('escape');
}

/* ── 2. PWA INSTALL PROMPT ────────────────────────────────── */
const oInstallEl = document.getElementById('vyr-install');

window.addEventListener('beforeinstallprompt', (e) => {
  e.preventDefault();
  oState.deferredPrompt = e;
  vyrLog('pwa_available');
  if (!oState.installDismissed) {
    const delay = oState.welcomeSeen ? 3500 : 7000;
    setTimeout(() => {
      if (oInstallEl) oInstallEl.classList.add('visible');
      vyrLog('pwa_prompt_shown');
    }, delay);
  }
});

window.addEventListener('appinstalled', () => {
  vyrLog('pwa_installed');
  oInstallHide();
});

async function oInstallTrigger() {
  if (!oState.deferredPrompt) return;
  vyrLog('pwa_install_clicked');
  oState.deferredPrompt.prompt();
  const { outcome } = await oState.deferredPrompt.userChoice;
  vyrLog('pwa_outcome', { outcome });
  oState.deferredPrompt = null;
  oInstallDismiss();
}

function oInstallDismiss() {
  oState.installDismissed = true;
  localStorage.setItem('vyr_install_dismissed', 'true');
  oInstallHide();
  vyrLog('pwa_dismissed');
}

function oInstallHide() {
  if (!oInstallEl) return;
  oInstallEl.classList.remove('visible');
  oInstallEl.classList.add('dismissed');
  setTimeout(() => { oInstallEl.style.display = 'none'; }, 600);
}

/* ── 3. FLOATING ORB ──────────────────────────────────────── */
const oOrbBtn   = document.getElementById('oo-btn');
const oOrbPanel = document.getElementById('oo-panel');

function oOrbToggle() {
  oState.orbOpen = !oState.orbOpen;
  if (oOrbBtn)   oOrbBtn.classList.toggle('open', oState.orbOpen);
  if (oOrbPanel) oOrbPanel.classList.toggle('open', oState.orbOpen);
  if (oOrbBtn)   oOrbBtn.setAttribute('aria-expanded', String(oState.orbOpen));
  if (oOrbPanel) oOrbPanel.setAttribute('aria-hidden', String(!oState.orbOpen));
  vyrLog('orb_toggled', { open: oState.orbOpen });
}

function oOrbClose() {
  oState.orbOpen = false;
  if (oOrbBtn)   { oOrbBtn.classList.remove('open'); oOrbBtn.setAttribute('aria-expanded','false'); }
  if (oOrbPanel) { oOrbPanel.classList.remove('open'); oOrbPanel.setAttribute('aria-hidden','true'); }
}

if (oOrbBtn) {
  oOrbBtn.addEventListener('keydown', e => {
    if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); oOrbToggle(); }
  });
}

document.addEventListener('click', (e) => {
  const orbEl = document.getElementById('vyr-orb');
  if (oState.orbOpen && orbEl && !orbEl.contains(e.target)) oOrbClose();
});

/* ── 4. SIDE PANEL ────────────────────────────────────────── */
const oPanelEl     = document.getElementById('vyr-panel');
const oBackdropEl  = document.getElementById('vyr-backdrop');

function oPanelOpen() {
  oState.panelOpen = true;
  if (oPanelEl)    { oPanelEl.classList.add('open'); oPanelEl.setAttribute('aria-hidden','false'); }
  if (oBackdropEl) oBackdropEl.classList.add('open');
  document.body.style.overflow = 'hidden';
  vyrLog('panel_opened');
}

function oPanelClose() {
  oState.panelOpen = false;
  if (oPanelEl)    { oPanelEl.classList.remove('open'); oPanelEl.setAttribute('aria-hidden','true'); }
  if (oBackdropEl) oBackdropEl.classList.remove('open');
  document.body.style.overflow = '';
  vyrLog('panel_closed');
}

document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    if (oState.panelOpen) oPanelClose();
    if (oState.orbOpen)   oOrbClose();
    if (!oState.welcomeSeen) oWelcomeDismiss('escape');
  }
});

/* ── 5. SCROLL NOTIFICATION ───────────────────────────────── */
const oScrollNotifEl = document.getElementById('vyr-scroll-notif');

function oScrollCheck() {
  if (oState.scrollNotifShown) return;
  const docH   = document.documentElement.scrollHeight - window.innerHeight;
  const pct    = docH > 0 ? (window.scrollY / docH) * 100 : 0;
  if (pct >= 40) {
    oState.scrollNotifShown = true;
    if (oScrollNotifEl) oScrollNotifEl.classList.add('show');
    vyrLog('scroll_notif_shown', { scrollPct: Math.round(pct) });
    setTimeout(() => {
      if (oScrollNotifEl) oScrollNotifEl.classList.remove('show');
    }, 3800);
  }
}

window.addEventListener('scroll', oScrollCheck, { passive: true });

/* ── INIT ─────────────────────────────────────────────────── */
(function oInit() {
  oWelcomeInit();
  vyrLog('onboarding_layer_init', {
    welcomeSeen:      oState.welcomeSeen,
    installDismissed: oState.installDismissed,
  });
})();
</script>
</body>
