const magEl  = document.getElementById('mag');
const magT   = document.getElementById('mag-t');
const magB   = document.getElementById('mag-b');
const magS   = document.getElementById('mag-s');
let mx = 0, my = 0, magActive = false;

document.addEventListener('mousemove', e => {
  mx = e.clientX; my = e.clientY;
  if (!magActive) return;
  positionMag();
});

function positionMag() {
  const PAD = 20, W = 300, H = magEl.offsetHeight || 180;
  const vw = window.innerWidth, vh = window.innerHeight;
  let x = mx + PAD, y = my - 14;
  if (x + W > vw - 6) x = mx - W - PAD;
  if (y + H > vh - 6) y = vh - H - 6;
  if (y < 6) y = 6;
  if (x < 6) x = 6;
  magEl.style.left = x + 'px';
  magEl.style.top  = y + 'px';
}

function attachMag(root) {
  (root || document).querySelectorAll('[data-mag]').forEach(el => {
    const fresh = el.cloneNode(true);
    el.parentNode?.replaceChild(fresh, el);
    fresh.addEventListener('mouseenter', () => {
      const d = getMag(fresh);
      if (!d) return;
      magT.textContent = d.t;
      magB.textContent = d.b;
      magS.textContent = d.s;
      magActive = true;
      positionMag();
      magEl.classList.add('show');
    });
    fresh.addEventListener('mouseleave', () => {
      magEl.classList.remove('show');
      magActive = false;
    });
  });
}

