// ─── SORT + FILTER ENGINE ────────────────────────────────
let activeBand = 'all';

function getSorted() {
  const s = document.getElementById('sort-sel')?.value || 'score-desc';
  return [...COMPANIES].sort((a, b) => {
    if (s === 'score-desc') return b.score - a.score;
    if (s === 'score-asc')  return a.score - b.score;
    if (s === 'name-asc')   return a.name.localeCompare(b.name);
    if (s === 'name-desc')  return b.name.localeCompare(a.name);
    if (s === 'lawsuits-desc') return b.sabin - a.sabin;
    if (s === 'sector-asc') return a.sector.localeCompare(b.sector);
    return 0;
  });
}

function applyFilters() {
  const q   = (document.getElementById('search-input')?.value || '').toLowerCase().trim();
  const sec = document.getElementById('sector-sel')?.value || 'all';
  const sorted = getSorted();
  const grid = document.getElementById('grid');
  grid.innerHTML = sorted.map(renderCard).join('');
  animateBars(grid);
  attachMag(grid);
  reattachEdgar();

  let vis = 0;
  sorted.forEach(co => {
    const card = document.getElementById('co-' + co.id);
    if (!card) return;
    const nameMatch = !q || co.name.toLowerCase().includes(q) || co.ticker.toLowerCase().includes(q);
    const bandMatch = activeBand === 'all' || co.band === activeBand;
    const secMatch  = sec === 'all' || co.sector === sec;
    const show = nameMatch && bandMatch && secMatch;
    card.classList.toggle('hidden', !show);
    if (show) vis++;
  });

  const vc = document.getElementById('vis-count');
  if (vc) vc.textContent = vis;
  const nr = document.getElementById('no-results');
  if (nr) nr.classList.toggle('show', vis === 0);
}

