function exportCSV() {
  const headers = ['Name','Ticker','Sector','Score','Band','CDP Grade','InfluenceMap','SBTi Status','Active Lawsuits','TPI Level','CIK','EDGAR Date'];
  const rows = COMPANIES.map(co => {
    const edEl = document.getElementById('ev-' + co.id);
