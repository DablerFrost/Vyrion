async function fetchCO2() {
  try {
    const r = await fetch('https://gml.noaa.gov/webdata/ccgg/trends/co2/co2_daily_mlo.txt');
    if (!r.ok) throw new Error();
    const txt = await r.text();
    const lines = txt.split('\n').filter(l => l.trim() && !l.startsWith('#'));
    for (let i = lines.length - 1; i >= 0; i--) {
      const p = lines[i].trim().split(/\s+/);
      if (p.length >= 5) {
        const v = parseFloat(p[4]);
        if (!isNaN(v) && v > 0) {
          return {
            ppm: v.toFixed(2),
            date: `${p[0]}-${p[1].padStart(2,'0')}-${p[2].padStart(2,'0')}`
          };
        }
      }
    }
  } catch(e) {}
  return null;
}

async function fetchEdgar(co) {
  try {
    const r = await fetch(`https://data.sec.gov/submissions/CIK${co.cik}.json`);
    if (!r.ok) throw new Error();
    const d = await r.json();
    const forms = d.filings.recent.form;
    const dates = d.filings.recent.filingDate;
    let annual = null, k8count = 0, k8recent = null;
    const cut90 = new Date(Date.now() - 90*86400000).toISOString().slice(0,10);
    for (let i = 0; i < forms.length; i++) {
      if (!annual && (forms[i]==='10-K'||forms[i]==='20-F')) {
        annual = { form:forms[i], date:dates[i] };
      }
      if (forms[i]==='8-K') {
        if (!k8recent) k8recent = dates[i];
        if (dates[i] >= cut90) k8count++;
      }
      if (annual && k8recent && dates[i] < cut90 && k8count > 0) break;
    }
    return { annual, k8count, k8recent, cik: co.cik.replace(/^0+/,'') };
  } catch(e) { return null; }
}

// ── updateEdgar — defined here, used by init() and reattachEdgar() (v2.8 fix) ──
function updateEdgar(co, data) {
  const vEl = document.getElementById('ev-'+co.id);
  const sEl = document.getElementById('es-'+co.id);
  if (!vEl || !sEl) return;
  if (data && data.annual) {
    const {annual, k8count, cik} = data;
    vEl.textContent = annual.date;
    vEl.classList.remove('loading-pulse');
    vEl.style.color = 'var(--glow)';
    vEl.style.fontSize = '.68rem';
    const url = `https://www.sec.gov/cgi-bin/browse-edgar?action=getcompany&CIK=${cik}&type=10-K`;
    let sub = `<a href="${url}" target="_blank" style="color:rgba(0,212,255,.38);text-decoration:none">${annual.form} filing →</a>`;
    if (k8count >= 3) {
      sub += `<span style="color:var(--warn);font-size:.52rem;display:block;margin-top:.06rem">${k8count} 8-K events / 90d ⚠</span>`;
    } else if (k8count > 0) {
      sub += `<span style="color:var(--t3);font-size:.52rem;display:block;margin-top:.06rem">${k8count} 8-K / 90d</span>`;
    }
    sEl.innerHTML = sub;
  } else {
    vEl.textContent = 'N/A';
    vEl.classList.remove('loading-pulse');
    vEl.style.color = 'var(--t3)';
    sEl.textContent = 'Offline';
  }
}

