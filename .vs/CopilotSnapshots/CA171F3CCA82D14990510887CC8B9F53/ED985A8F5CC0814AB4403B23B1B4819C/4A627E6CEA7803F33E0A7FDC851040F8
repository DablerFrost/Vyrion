<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta name="description" content="VYRION CONSCIENCE — Corporate Climate Pledge Tracker. Pledge vs. reality for 11 major corporations, scored against Paris Agreement 1.5°C pathways.">
<meta property="og:title" content="VYRION CONSCIENCE — Corporate Climate Pledge Tracker">
<meta property="og:description" content="Pledge vs. reality for 11 major corporations. Scores derived from CDP, InfluenceMap, Sabin Center, SBTi registry, and live SEC EDGAR filings.">
<meta property="og:url" content="https://vyrion.earth/">
<meta property="og:type" content="website">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="VYRION CONSCIENCE">
<meta name="twitter:description" content="Corporate climate pledge accountability. 11 companies scored against Paris Agreement 1.5°C pathways.">
<link rel="canonical" href="https://vyrion.earth/">
<title>VYRION CONSCIENCE — Corporate Climate Pledge Tracker</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;700;800&family=Archivo:wght@400;500;600&family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
<style>
/* ── THEME ─────────────────────────────────────────────── */
:root{
  --void:#020912;--void2:#061624;--void3:#0b2035;
  --glow:#00D4FF;--amber:#FFB84D;--breach:#F03030;--warn:#F09000;
  --t1:#e4f2ff;--t2:#6a9ab8;--t3:#2d6080;
  --border:rgba(0,212,255,.12);--border2:rgba(0,212,255,.07);
  --breach-bg:rgba(240,48,48,.07);--warn-bg:rgba(240,144,0,.07);--track-bg:rgba(0,212,255,.07);
  --nav-bg:rgba(2,9,18,.97);--mag-bg:rgba(3,12,24,.98);
  --scanline:rgba(0,212,255,.004);
  --pad:2rem;
}
[data-theme="light"]{
  --void:#f0f5ff;--void2:#e4eeff;--void3:#d5e5ff;
  --glow:#0066CC;--amber:#b07800;--breach:#b82020;--warn:#a05800;
  --t1:#060e1e;--t2:#1e4a7a;--t3:#3a6090;
  --border:rgba(0,102,204,.18);--border2:rgba(0,102,204,.10);
  --breach-bg:rgba(184,32,32,.09);--warn-bg:rgba(160,88,0,.09);--track-bg:rgba(0,102,204,.09);
  --nav-bg:rgba(240,245,255,.98);--mag-bg:rgba(235,244,255,.99);
  --scanline:transparent;
}

/* ── RESET ─────────────────────────────────────────────── */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:18px}
body{
  background:var(--void);color:var(--t1);
  font-family:'Archivo',sans-serif;font-size:1rem;
  line-height:1.65;min-height:100vh;overflow-x:hidden;
  transition:background .3s,color .3s;
}
body::after{
  content:'';position:fixed;inset:0;pointer-events:none;z-index:990;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,var(--scanline) 3px,var(--scanline) 4px);
}
.nav,.live-banner,.c-card,.v-badge,.method-section,.footer,.src-badge,.lb-cell,.filter-bar,.source-strip,.page-header,.score-breakdown{
  transition:background .3s,border-color .3s;
}

/* ── NAV ────────────────────────────────────────────────── */
.nav{
  position:sticky;top:0;z-index:500;height:52px;
  display:flex;align-items:center;gap:1rem;padding:0 1.8rem;
  background:var(--nav-bg);border-bottom:1px solid var(--border);
  backdrop-filter:blur(20px);
}
.nav-logo{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;font-size:.95rem;
  color:var(--glow);letter-spacing:.15em;text-decoration:none;flex-shrink:0;
}
.nav-links{display:flex;gap:1.8rem;list-style:none;flex:1}
.nav-links a{
  font-family:'Archivo Narrow',sans-serif;font-weight:700;font-size:.65rem;
  letter-spacing:.16em;text-transform:uppercase;
  color:var(--t2);text-decoration:none;transition:color .2s;padding-bottom:2px;
}
.nav-links a:hover{color:var(--t1)}
.nav-links a.active{color:var(--glow);border-bottom:1px solid rgba(0,212,255,.4)}
.nav-dot{width:6px;height:6px;background:var(--glow);border-radius:50%;flex-shrink:0;animation:pdot 2.2s infinite}
@keyframes pdot{0%,100%{opacity:1;box-shadow:0 0 0 0 rgba(0,212,255,.5)}50%{opacity:.4;box-shadow:0 0 0 7px rgba(0,255,157,0)}}

/* ── NAV CONTROLS ───────────────────────────────────────── */
.nav-controls{display:flex;align-items:center;gap:.35rem;flex-shrink:0}
.nc-sep{width:1px;height:16px;background:var(--border);margin:0 .15rem}
.nc-theme{
  font-family:'Courier Prime',monospace;font-size:.58rem;font-weight:700;
  letter-spacing:.12em;padding:.22rem .5rem;border-radius:2px;
  border:1px solid var(--border);background:transparent;
  color:var(--t2);cursor:pointer;transition:all .2s;white-space:nowrap;
}
.nc-theme:hover,.nc-theme.active{
  border-color:var(--glow);color:var(--glow);
  background:rgba(0,212,255,.08);box-shadow:0 0 8px rgba(0,212,255,.12);
}
[data-theme="light"] .nc-theme:hover,[data-theme="light"] .nc-theme.active{
  border-color:var(--glow);color:var(--glow);background:rgba(0,136,68,.1);box-shadow:none;
}
.nc-sz{
  font-family:'Courier Prime',monospace;font-size:.6rem;font-weight:700;
  width:26px;height:26px;display:flex;align-items:center;justify-content:center;
  border-radius:2px;border:1px solid var(--border);
  background:transparent;color:var(--t3);cursor:pointer;transition:all .2s;
}
.nc-sz:hover{border-color:rgba(0,212,255,.4);color:var(--t1)}
.nc-sz.active{
  background:rgba(0,212,255,.15);
  border-color:var(--glow);color:var(--glow);
  box-shadow:0 0 8px rgba(0,212,255,.2);
}
[data-theme="light"] .nc-sz.active{
  background:rgba(0,136,68,.12);border-color:var(--glow);
  color:var(--glow);box-shadow:none;
}

/* ── LIVE TICKER ────────────────────────────────────────── */
.live-banner{
  display:flex;flex-wrap:wrap;
  background:var(--void2);border-bottom:1px solid var(--border);
}
.lb-cell{
  flex:1;min-width:120px;padding:.75rem 1.4rem;
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;gap:.12rem;
}
.lb-cell:last-child{border-right:none}
.lb-lbl{
  font-family:'Courier Prime',monospace;font-size:.55rem;
  color:var(--t3);letter-spacing:.18em;text-transform:uppercase;
  display:flex;align-items:center;gap:.35rem;
}
.lb-dot{
  width:4px;height:4px;background:var(--glow);border-radius:50%;
  animation:pdot 2s infinite;flex-shrink:0;
}
.lb-val{
  font-family:'Courier Prime',monospace;font-weight:700;
  font-size:1.05rem;color:var(--glow);line-height:1;letter-spacing:-.01em;
}
.lb-val.amber{color:var(--amber)}
.lb-val.red{color:var(--breach)}
.lb-val.white{color:var(--t1)}
.lb-sub{font-family:'Courier Prime',monospace;font-size:.54rem;color:var(--t3);line-height:1.3}

/* ── PAGE HEADER ─────────────────────────────────────────── */
.page-header{
  padding:3.5rem 2rem 2.8rem;border-bottom:1px solid var(--border);
  position:relative;overflow:hidden;
  background-image:url('https://okay-gold-oof5kipmvh.edgeone.app/Testing%20The%20Surface%20-%20Imgur.png');
  background-size:cover;background-position:center 38%;
}
.page-header::before{
  content:'';position:absolute;inset:0;z-index:0;
  background:linear-gradient(120deg,rgba(2,9,18,.94) 0%,rgba(2,9,18,.76) 45%,rgba(2,9,18,.90) 100%);
  transition:background .3s;
}
[data-theme="light"] .page-header::before{
  background:linear-gradient(120deg,rgba(238,248,255,.96) 0%,rgba(238,248,255,.82) 45%,rgba(238,248,255,.93) 100%);
}
.page-header::after{
  content:'';position:absolute;inset:0;z-index:1;pointer-events:none;
  background:radial-gradient(ellipse 55% 60% at 72% 52%,rgba(0,212,255,.06) 0%,transparent 70%);
  animation:hpulse 7s ease-in-out infinite alternate;
}
@keyframes hpulse{0%{opacity:.4;transform:scale(1)}100%{opacity:1;transform:scale(1.05)}}
.page-header>*{position:relative;z-index:2}
.bg-word{
  position:absolute;right:-1.5rem;top:50%;transform:translateY(-50%);
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:clamp(5rem,13vw,10rem);
  color:rgba(0,212,255,.03);pointer-events:none;user-select:none;z-index:2;
}
.eyebrow{
  font-family:'Courier Prime',monospace;font-size:.65rem;color:var(--glow);
  letter-spacing:.24em;text-transform:uppercase;margin-bottom:.55rem;
  display:flex;align-items:center;gap:.55rem;
}
.eyebrow::before{content:'';width:18px;height:1px;background:var(--glow);opacity:.5}
.page-title{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:clamp(2.4rem,5.5vw,3.8rem);color:var(--t1);
  line-height:.95;letter-spacing:-.02em;margin-bottom:.65rem;
}
.page-sub{font-size:.82rem;color:var(--t2);max-width:62ch;line-height:1.72}

/* ── SOURCE STRIP ────────────────────────────────────────── */
.source-strip{display:flex;flex-wrap:wrap;background:var(--void2);border-bottom:1px solid var(--border)}
.src-badge{
  flex:1;min-width:120px;padding:.8rem 1.1rem;
  border-right:1px solid var(--border);
  display:flex;flex-direction:column;gap:.2rem;
}
.src-badge:last-child{border-right:none}
.src-name{
  font-family:'Courier Prime',monospace;font-size:.6rem;
  letter-spacing:.12em;text-transform:uppercase;
  display:flex;align-items:center;gap:.38rem;
}
.src-status{font-family:'Courier Prime',monospace;font-size:.56rem;color:var(--t3);line-height:1.3}
.src-link{font-family:'Courier Prime',monospace;font-size:.54rem;color:rgba(0,212,255,.3);text-decoration:none;transition:color .18s}
.src-link:hover{color:var(--glow)}
.dot-live{width:5px;height:5px;background:var(--glow);border-radius:50%;flex-shrink:0;animation:pdot 2.2s infinite}
.dot-static{width:5px;height:5px;background:var(--t3);border-radius:50%;flex-shrink:0}

/* ── FILTER BAR ──────────────────────────────────────────── */
.filter-bar{
  display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;
  gap:.7rem;padding:.8rem 2rem;border-bottom:1px solid var(--border);
  background:var(--void2);
}
.filter-btns{display:flex;gap:.4rem;flex-wrap:wrap}
.f-btn{
  font-family:'Courier Prime',monospace;font-size:.6rem;
  letter-spacing:.1em;text-transform:uppercase;
  padding:.26rem .7rem;border-radius:2px;border:1px solid var(--border);
  background:transparent;color:var(--t2);cursor:pointer;transition:all .18s;
}
.f-btn:hover{border-color:rgba(0,212,255,.35);color:var(--t1)}
.f-btn.active{background:rgba(0,212,255,.09);border-color:rgba(0,212,255,.5);color:var(--glow)}
.f-btn.active.fb-breach{background:var(--breach-bg);border-color:rgba(240,48,48,.4);color:var(--breach)}
.f-btn.active.fb-warn{background:var(--warn-bg);border-color:rgba(240,144,0,.4);color:var(--warn)}
.f-btn.active.fb-track{background:var(--track-bg);border-color:rgba(0,212,255,.5);color:var(--glow)}
.fstats{display:flex;gap:1.3rem;flex-wrap:wrap}
.fst{font-family:'Courier Prime',monospace;font-size:.58rem;color:var(--t3);display:flex;align-items:center;gap:.28rem}
.fst b{font-weight:700}
.fst.breach b{color:var(--breach)}.fst.warn b{color:var(--warn)}.fst.track b{color:var(--glow)}.fst.tot b{color:var(--t1)}

/* ── COMPANY GRID ────────────────────────────────────────── */
.company-grid{
  display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));
  gap:1px;background:var(--border);
}

/* ── COMPANY CARD ────────────────────────────────────────── */
.c-card{
  background:var(--void2);padding:1.35rem;
  display:flex;flex-direction:column;
  position:relative;overflow:hidden;
  transition:background .2s,transform .2s;
}
.c-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:var(--card-accent,rgba(0,212,255,.06));
  transition:opacity .2s;
}
.c-card:hover{background:var(--void3)}
.c-card[data-band="breach"]{--card-accent:var(--breach)}
.c-card[data-band="warning"]{--card-accent:var(--warn)}
.c-card[data-band="on-track"]{--card-accent:var(--glow)}
.c-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:.8rem;gap:.5rem}
.c-name{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:1.12rem;color:var(--t1);letter-spacing:.04em;line-height:1;
}
.c-meta{font-family:'Courier Prime',monospace;font-size:.55rem;color:var(--t3);margin-top:.18rem;letter-spacing:.06em}
.c-score-wrap{text-align:right;flex-shrink:0}
.c-score-num{
  font-family:'Courier Prime',monospace;font-weight:700;
  font-size:1.75rem;line-height:1;letter-spacing:-.02em;
}
.c-score-den{font-family:'Courier Prime',monospace;font-size:.66rem;color:var(--t3)}
.c-band{
  font-family:'Courier Prime',monospace;font-size:.54rem;
  letter-spacing:.14em;text-transform:uppercase;
  margin-top:.08rem;text-align:right;padding:.09rem .38rem;border-radius:2px;
  display:inline-block;
}
.band-breach .c-score-num{color:var(--breach)}
.band-breach .c-band{background:var(--breach-bg);color:var(--breach);border:1px solid rgba(240,48,48,.3)}
.band-warning .c-score-num{color:var(--warn)}
.band-warning .c-band{background:var(--warn-bg);color:var(--warn);border:1px solid rgba(240,144,0,.3)}
.band-track .c-score-num{color:var(--glow)}
.band-track .c-band{background:var(--track-bg);color:var(--glow);border:1px solid rgba(0,212,255,.3)}

/* Score bar */
.score-bar-wrap{margin-bottom:.9rem}
.score-bar-bg{
  height:3px;background:rgba(255,255,255,.06);
  border-radius:2px;overflow:hidden;margin-bottom:.22rem;
}
[data-theme="light"] .score-bar-bg{background:rgba(0,0,0,.08)}
.score-bar-fill{height:100%;border-radius:2px;width:0;transition:width 1.4s cubic-bezier(.4,0,.2,1)}
.band-breach .score-bar-fill{background:linear-gradient(90deg,rgba(240,48,48,.4),var(--breach))}
.band-warning .score-bar-fill{background:linear-gradient(90deg,rgba(240,144,0,.4),var(--warn))}
.band-track .score-bar-fill{background:linear-gradient(90deg,rgba(0,212,255,.3),var(--glow))}
.score-bar-labels{display:flex;justify-content:space-between;font-family:'Courier Prime',monospace;font-size:.52rem;color:var(--t3)}

/* Pledge / Reality */
.pr-block{margin-bottom:.8rem}
.pr-row{display:flex;gap:.5rem;margin-bottom:.3rem;align-items:flex-start}
.pr-tag{
  font-family:'Courier Prime',monospace;font-size:.54rem;letter-spacing:.1em;
  text-transform:uppercase;flex-shrink:0;padding:.09rem .28rem;
  border-radius:2px;margin-top:.13rem;line-height:1.2;
}
.tag-pledge{background:rgba(74,173,255,.08);color:#4AADFF;border:1px solid rgba(74,173,255,.25)}
.tag-reality{background:var(--breach-bg);color:var(--breach);border:1px solid rgba(240,48,48,.25)}
.tag-reality.warn{background:var(--warn-bg);color:var(--warn);border:1px solid rgba(240,144,0,.25)}
.tag-reality.ok{background:var(--track-bg);color:var(--glow);border:1px solid rgba(0,212,255,.25)}
.pr-text{font-size:.73rem;color:var(--t1);line-height:1.52}
.pr-src{
  font-family:'Courier Prime',monospace;font-size:.56rem;color:var(--t3);
  margin-left:calc(.28rem + 43px + .5rem);margin-top:-.18rem;margin-bottom:.2rem;
}
.pr-src a{color:rgba(0,212,255,.35);text-decoration:none;transition:color .18s}
.pr-src a:hover{color:var(--glow)}

/* Validation badges */
.val-grid{
  display:grid;grid-template-columns:repeat(3,1fr);gap:.32rem;
  margin-bottom:.7rem;padding-top:.7rem;border-top:1px solid var(--border2);
}
.v-badge{
  display:flex;flex-direction:column;gap:.1rem;
  padding:.45rem .44rem .4rem;border-radius:2px;
  border:1px solid var(--border2);background:rgba(0,0,0,.16);
  transition:border-color .18s,background .18s;
}
.v-badge:hover{border-color:rgba(0,212,255,.22);background:rgba(0,0,0,.26)}
[data-theme="light"] .v-badge{background:rgba(0,0,0,.04)}
[data-theme="light"] .v-badge:hover{background:rgba(0,0,0,.08)}
.v-badge a{text-decoration:none;color:inherit;display:block}
.v-name{font-family:'Courier Prime',monospace;font-size:.52rem;color:var(--t3);letter-spacing:.08em;text-transform:uppercase}
.v-val{font-family:'Courier Prime',monospace;font-weight:700;font-size:.82rem;line-height:1.1}
.v-sub{font-family:'Courier Prime',monospace;font-size:.52rem;color:var(--t3);line-height:1.3}
.cdp-A{color:var(--glow)}.cdp-B{color:var(--amber)}.cdp-C{color:var(--warn)}.cdp-D{color:var(--breach)}
.im-A{color:var(--glow)}.im-B{color:var(--amber)}.im-C{color:var(--warn)}.im-D,.im-F{color:var(--breach)}
.sbti-yes{color:var(--glow)}.sbti-commit{color:var(--amber)}.sbti-no{color:var(--breach)}
.law-0{color:var(--glow)}.law-low{color:var(--amber)}.law-mid{color:var(--warn)}.law-high{color:var(--breach)}

/* Score breakdown */
.expand-toggle{
  display:flex;align-items:center;justify-content:space-between;
  padding:.4rem .52rem;border:1px solid var(--border2);border-radius:2px;
  cursor:pointer;background:transparent;width:100%;
  color:var(--t3);font-family:'Courier Prime',monospace;font-size:.58rem;
  letter-spacing:.08em;transition:all .18s;
}
.expand-toggle:hover{border-color:rgba(0,212,255,.25);color:var(--t2)}
.expand-toggle.open{border-color:rgba(0,212,255,.2);color:var(--t2)}
.chevron{transition:transform .22s;font-size:.52rem;flex-shrink:0}
.expand-toggle.open .chevron{transform:rotate(180deg)}
.score-breakdown{
  display:none;margin-top:.4rem;padding:.6rem .52rem;
  background:rgba(0,0,0,.25);border:1px solid var(--border2);border-radius:2px;
}
.score-breakdown.open{display:block}
[data-theme="light"] .score-breakdown{background:rgba(0,0,0,.04)}
.sb-row{
  display:flex;justify-content:space-between;align-items:baseline;
  padding:.16rem 0;border-bottom:1px solid rgba(255,255,255,.04);
  font-family:'Courier Prime',monospace;font-size:.6rem;
}
.sb-row:last-child{border-bottom:none}
[data-theme="light"] .sb-row{border-bottom-color:rgba(0,0,0,.06)}
.sb-f{color:var(--t2);flex:1;padding-right:.5rem}
.sb-w{color:var(--t3);font-size:.54rem;flex-shrink:0;padding-right:.6rem}
.sb-p{color:var(--t1);font-weight:700;flex-shrink:0;text-align:right;min-width:36px}
.sb-total{
  display:flex;justify-content:space-between;padding:.28rem 0 0;
  margin-top:.2rem;border-top:1px solid var(--border);
  font-family:'Courier Prime',monospace;font-size:.64rem;
}
.sb-total .sb-f{color:var(--t1)}
.sb-note{
  font-family:'Courier Prime',monospace;font-size:.54rem;color:var(--t3);
  margin-top:.42rem;padding-top:.38rem;border-top:1px solid var(--border2);line-height:1.5;
}
.sb-note a{color:rgba(0,212,255,.35);text-decoration:none}
.sb-note a:hover{color:var(--glow)}

/* ── METHODOLOGY ─────────────────────────────────────────── */
.method-section{border-top:1px solid var(--border);padding:2rem;background:var(--void2)}
.method-title{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;
  font-size:.85rem;letter-spacing:.13em;text-transform:uppercase;
  color:var(--t1);margin-bottom:.75rem;
}
.method-body{font-size:.75rem;color:var(--t2);line-height:1.75;max-width:78ch}
.method-body a{color:rgba(0,212,255,.5);text-decoration:none}
.method-body a:hover{color:var(--glow)}
.method-table{width:100%;border-collapse:collapse;margin-top:.9rem;font-family:'Courier Prime',monospace;font-size:.63rem}
.method-table th{
  text-align:left;padding:.38rem .75rem .38rem 0;
  color:var(--t3);letter-spacing:.08em;text-transform:uppercase;
  border-bottom:1px solid var(--border);font-weight:400;
}
.method-table td{padding:.38rem .75rem .38rem 0;color:var(--t2);border-bottom:1px solid var(--border2)}
.method-table td:last-child{color:var(--t1)}

/* ── FOOTER ──────────────────────────────────────────────── */
.footer{
  display:flex;align-items:center;justify-content:space-between;
  flex-wrap:wrap;gap:1rem;padding:1.4rem 2rem;border-top:1px solid var(--border);
}
.footer-l{font-family:'Courier Prime',monospace;font-size:.6rem;color:var(--t3);line-height:1.75}
.footer-l a{color:rgba(0,212,255,.4);text-decoration:none;transition:color .18s}
.footer-l a:hover{color:var(--glow)}
.footer-r{display:flex;gap:1.4rem}
.footer-r a{font-family:'Courier Prime',monospace;font-size:.6rem;color:rgba(0,212,255,.3);text-decoration:none;transition:color .18s}
.footer-r a:hover{color:var(--glow)}

/* ── MAGNIFIER — z-index 9500 ────────────────────────────── */
#mag{
  position:fixed;pointer-events:none;z-index:9500;
  width:300px;opacity:0;
  transition:opacity .14s cubic-bezier(.4,0,.2,1);
  will-change:transform,opacity;
}
#mag.show{opacity:1}
.mag-box{
  background:var(--mag-bg);
  border:1px solid rgba(0,212,255,.2);border-radius:3px;
  padding:.85rem .95rem;
  box-shadow:0 16px 48px rgba(0,0,0,.7),0 0 0 1px rgba(0,212,255,.05);
  position:relative;overflow:hidden;
}
[data-theme="light"] .mag-box{
  border-color:rgba(0,136,68,.22);
  box-shadow:0 8px 28px rgba(0,0,0,.14);
}
.mag-box::before{
  content:'';position:absolute;top:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,rgba(0,212,255,.55),transparent);
}
[data-theme="light"] .mag-box::before{background:linear-gradient(90deg,transparent,rgba(0,136,68,.4),transparent)}
.mag-brand{
  font-family:'Archivo Narrow',sans-serif;font-weight:800;font-size:.55rem;
  letter-spacing:.24em;text-transform:uppercase;color:rgba(0,212,255,.35);
  margin-bottom:.38rem;display:flex;align-items:center;gap:.4rem;
}
.mag-brand::before{
  content:'';width:4px;height:4px;background:var(--glow);border-radius:50%;
  opacity:.6;animation:pdot 2s infinite;flex-shrink:0;
}
.mag-title{
  font-family:'Archivo Narrow',sans-serif;font-weight:700;
  font-size:.8rem;color:var(--t1);margin-bottom:.34rem;line-height:1.3;
}
.mag-body{font-size:.7rem;color:var(--t2);line-height:1.55;margin-bottom:.42rem}
.mag-src{
  font-family:'Courier Prime',monospace;font-size:.57rem;
  color:rgba(0,212,255,.38);border-top:1px solid var(--border2);
  padding-top:.35rem;line-height:1.5;
}
[data-theme="light"] .mag-src{color:rgba(0,136,68,.5)}

/* ── UTILS ───────────────────────────────────────────────── */
.loading-pulse{animation:pulse 1.4s infinite}
@keyframes pulse{0%,100%{opacity:.3}50%{opacity:.75}}
.hidden{display:none!important}

/* ── ONBOARDING LAYER TOKENS ─────────────────────────────── */
:root {
  --ov-glass:   rgba(2, 9, 18, 0.88);
  --ov-surface: rgba(6, 22, 44, 0.72);
  --ov-border:  rgba(0, 212, 255, 0.18);
  --ov-glow:    0 0 32px rgba(0, 212, 255, 0.35);
  --ov-ease:    cubic-bezier(0.22, 1, 0.36, 1);
}

/* ── 1. WELCOME OVERLAY — z-index 9999 ───────────────────── */
#vyr-welcome {
  position: fixed; inset: 0; z-index: 9999;
  display: flex; align-items: center; justify-content: center;
  padding: 20px;
  background: radial-gradient(
    ellipse at 50% 42%,
    rgba(0, 50, 100, 0.65) 0%,
    rgba(2, 9, 18, 0.97) 68%
  );
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  opacity: 0;
  animation: oWelcomeIn 0.85s 0.25s var(--ov-ease) forwards;
}
@keyframes oWelcomeIn { to { opacity: 1; } }
#vyr-welcome.dismissed {
  animation: oWelcomeOut 0.5s var(--ov-ease) forwards;
}
@keyframes oWelcomeOut { to { opacity: 0; pointer-events: none; } }

.ov-inner {
  max-width: 540px; width: 100%;
  padding: 50px 42px;
  text-align: center;
  background: var(--ov-glass);
  border: 1px solid rgba(0, 212, 255, 0.22);
  border-radius: 20px;
  box-shadow:
    0 0 80px rgba(0, 80, 180, 0.22),
    inset 0 1px 0 rgba(255, 255, 255, 0.04);
  opacity: 0;
  transform: translateY(28px);
  animation: oInnerRise 0.85s 0.38s var(--ov-ease) forwards;
}
@keyframes oInnerRise { to { transform: translateY(0); opacity: 1; } }

.ov-eyebrow {
  font-family: 'Courier Prime', monospace;
  font-size: 0.6rem;
  letter-spacing: 0.26em;
  color: var(--glow);
  text-transform: uppercase;
  margin-bottom: 24px;
  display: flex; align-items: center; justify-content: center; gap: 10px;
}
.ov-eyebrow::before, .ov-eyebrow::after {
  content: '';
  width: 36px; height: 1px;
  background: linear-gradient(90deg, transparent, var(--glow));
  opacity: 0.5;
}
.ov-eyebrow::after { transform: scaleX(-1); }

.ov-globe {
  width: 68px; height: 68px;
  margin: 0 auto 26px;
  position: relative;
}
.ov-globe svg {
  width: 100%; height: 100%;
  filter: drop-shadow(0 0 14px rgba(0, 212, 255, 0.55));
}
.ov-ring {
  position: absolute;
  inset: -10px; border-radius: 50%;
  border: 1px solid rgba(0, 212, 255, 0.16);
  animation: oRingPulse 3.2s ease-in-out infinite;
}
.ov-ring:nth-child(3) {
  inset: -20px;
  border-color: rgba(0, 212, 255, 0.07);
  animation-delay: 1.1s;
}
@keyframes oRingPulse {
  0%,100% { transform: scale(1); opacity: 0.6; }
  50%      { transform: scale(1.07); opacity: 1; }
}

.ov-title {
  font-family: 'Archivo Narrow', sans-serif;
  font-weight: 800;
  font-size: clamp(1.5rem, 4vw, 2rem);
  letter-spacing: -0.01em;
  line-height: 1.15;
  color: var(--t1);
  margin-bottom: 16px;
}
.ov-title span { color: var(--glow); }

.ov-sub {
  font-family: 'Archivo', sans-serif;
  font-size: 0.84rem;
  color: var(--t2);
  line-height: 1.75;
  margin-bottom: 36px;
  font-weight: 400;
}

.ov-actions {
  display: flex; gap: 12px;
  justify-content: center; flex-wrap: wrap;
}

.ov-btn-primary {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 13px 26px;
  background: linear-gradient(135deg, rgba(0,212,255,0.18), rgba(0,100,200,0.28));
  border: 1px solid rgba(0, 212, 255, 0.5);
  border-radius: 4px;
  color: var(--glow);
  font-family: 'Courier Prime', monospace;
  font-size: 0.66rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  cursor: pointer;
  box-shadow: 0 0 18px rgba(0, 212, 255, 0.2);
  transition: box-shadow 0.2s, transform 0.18s var(--ov-ease), background 0.2s;
}
.ov-btn-primary:hover {
  box-shadow: 0 0 34px rgba(0, 212, 255, 0.45);
  transform: scale(1.04);
  background: linear-gradient(135deg, rgba(0,212,255,0.26), rgba(0,100,200,0.38));
}
.ov-btn-primary:active { transform: scale(0.97); }

.ov-btn-ghost {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 12px 24px;
  background: transparent;
  border: 1px solid rgba(0, 212, 255, 0.18);
  border-radius: 4px;
  color: var(--t2);
  font-family: 'Courier Prime', monospace;
  font-size: 0.66rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s, transform 0.18s var(--ov-ease);
}
.ov-btn-ghost:hover {
  border-color: rgba(0, 212, 255, 0.4);
  color: var(--t1);
  transform: scale(1.04);
}
.ov-btn-ghost:active { transform: scale(0.97); }

.ov-divider {
  margin: 28px 0 18px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--ov-border), transparent);
}
.ov-footer {
  font-family: 'Courier Prime', monospace;
  font-size: 0.58rem;
  color: var(--t3);
  letter-spacing: 0.1em;
}

/* ── 2. PWA INSTALL PROMPT ───────────────────────────────── */
#vyr-install {
  position: fixed;
  bottom: 24px; left: 24px;
  z-index: 8500;
  max-width: 350px;
  display: flex; align-items: center; gap: 13px;
  padding: 16px 18px;
  background: rgba(2, 9, 18, 0.94);
  backdrop-filter: blur(22px);
  border: 1px solid rgba(0, 212, 255, 0.22);
  border-radius: 10px;
  box-shadow: 0 8px 38px rgba(0,0,0,0.55), 0 0 20px rgba(0,212,255,0.1);
  transform: translateY(110px);
  opacity: 0;
  transition: transform 0.55s var(--ov-ease), opacity 0.55s var(--ov-ease);
}
#vyr-install.visible { transform: translateY(0); opacity: 1; }
#vyr-install.dismissed { transform: translateY(110px); opacity: 0; }

.oi-icon {
  flex-shrink: 0; width: 40px; height: 40px;
  background: linear-gradient(135deg, rgba(0,212,255,0.18), rgba(0,100,200,0.3));
  border: 1px solid rgba(0,212,255,0.3); border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.15rem;
}
.oi-text { flex: 1; }
.oi-text strong {
  display: block;
  font-family: 'Courier Prime', monospace; font-size: 0.62rem;
  font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--glow); margin-bottom: 3px;
}
.oi-text span {
  font-family: 'Archivo', sans-serif; font-size: 0.75rem;
  color: var(--t2); line-height: 1.4;
}
.oi-actions { display: flex; flex-direction: column; gap: 5px; flex-shrink: 0; }
.oi-btn-install {
  padding: 7px 13px;
  background: rgba(0,212,255,0.12); border: 1px solid rgba(0,212,255,0.4);
  border-radius: 3px; color: var(--glow);
  font-family: 'Courier Prime', monospace; font-size: 0.6rem;
  font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
  cursor: pointer;
  transition: background 0.15s, box-shadow 0.15s, transform 0.15s;
}
.oi-btn-install:hover { background: rgba(0,212,255,0.22); box-shadow: 0 0 12px rgba(0,212,255,0.3); transform: scale(1.04); }
.oi-btn-dismiss {
  padding: 5px 7px; background: transparent; border: none;
  color: var(--t3); font-family: 'Courier Prime', monospace;
  font-size: 0.58rem; letter-spacing: 0.06em; cursor: pointer; text-align: center;
  transition: color 0.15s;
}
.oi-btn-dismiss:hover { color: var(--t2); }

/* ── 3. FLOATING ORB ─────────────────────────────────────── */
#vyr-orb {
  position: fixed; bottom: 28px; right: 28px;
  z-index: 8000; width: 58px; height: 58px;
}
.oo-btn {
  width: 100%; height: 100%; border-radius: 50%;
  background: radial-gradient(circle at 36% 36%, rgba(0,212,255,0.35), rgba(0,60,140,0.7));
  border: 1.5px solid rgba(0,212,255,0.45);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  animation: oOrbPulse 3s ease-in-out infinite;
  transition: transform 0.2s var(--ov-ease), border-color 0.2s;
  box-shadow: 0 0 0 0 rgba(0,212,255,0.45);
}
.oo-btn:hover { transform: scale(1.12); animation: none; border-color: var(--glow); box-shadow: 0 0 22px rgba(0,212,255,0.4); }
.oo-btn:active { transform: scale(0.94); }
@keyframes oOrbPulse {
  0%   { box-shadow: 0 0 0 0 rgba(0,212,255,0.5); }
  65%  { box-shadow: 0 0 0 14px rgba(0,212,255,0); }
  100% { box-shadow: 0 0 0 0 rgba(0,212,255,0); }
}
.oo-icon {
  font-family: 'Archivo Narrow', sans-serif; font-weight: 800;
  font-size: 1.1rem; color: var(--glow);
  letter-spacing: 0; line-height: 1;
  transition: transform 0.3s var(--ov-ease); user-select: none;
}
.oo-btn.open .oo-icon { transform: rotate(45deg); }
.oo-tooltip {
  position: absolute; right: calc(100% + 10px); top: 50%;
  transform: translateY(-50%); white-space: nowrap;
  background: rgba(2,9,18,0.94); border: 1px solid var(--ov-border);
  border-radius: 4px; padding: 5px 11px;
  font-family: 'Courier Prime', monospace; font-size: 0.62rem;
  letter-spacing: 0.07em; color: var(--t2);
  pointer-events: none; opacity: 0; transition: opacity 0.18s;
}
#vyr-orb:hover .oo-tooltip { opacity: 1; }
.oo-panel {
  position: absolute; bottom: calc(100% + 10px); right: 0;
  width: 215px;
  background: rgba(2, 9, 18, 0.96); backdrop-filter: blur(24px);
  border: 1px solid var(--ov-border); border-radius: 10px; padding: 5px;
  opacity: 0; transform: scale(0.88) translateY(8px);
  transform-origin: bottom right; pointer-events: none;
  transition: opacity 0.22s var(--ov-ease), transform 0.22s var(--ov-ease);
  box-shadow: 0 14px 44px rgba(0,0,0,0.55);
}
.oo-panel.open { opacity: 1; transform: scale(1) translateY(0); pointer-events: auto; }
.oo-panel-header {
  padding: 9px 13px 7px;
  font-family: 'Courier Prime', monospace; font-size: 0.56rem;
  letter-spacing: 0.2em; color: var(--glow); text-transform: uppercase;
  border-bottom: 1px solid var(--ov-border); margin-bottom: 4px;
}
.oo-link {
  display: flex; align-items: center; gap: 9px;
  padding: 9px 13px; border-radius: 6px; color: var(--t2);
  font-family: 'Archivo', sans-serif; font-size: 0.78rem;
  transition: background 0.14s, color 0.14s; cursor: pointer; text-decoration: none;
}
.oo-link:hover { background: rgba(0,212,255,0.07); color: var(--t1); }
.oo-dot { width: 5px; height: 5px; border-radius: 50%; flex-shrink: 0; background: var(--glow); box-shadow: 0 0 5px var(--glow); }
.oo-link:nth-child(2) .oo-dot { background: var(--amber); box-shadow: 0 0 5px var(--amber); }
.oo-link:nth-child(3) .oo-dot { background: var(--warn); box-shadow: 0 0 5px var(--warn); }
.oo-link:nth-child(4) .oo-dot { background: var(--void3); box-shadow: 0 0 5px var(--void3); }

/* ── 4. SIDE PANEL ───────────────────────────────────────── */
#vyr-backdrop {
  position: fixed; inset: 0; z-index: 7500;
  background: rgba(2, 9, 18, 0.65); backdrop-filter: blur(4px);
  opacity: 0; pointer-events: none; transition: opacity 0.35s;
}
#vyr-backdrop.open { opacity: 1; pointer-events: auto; }
#vyr-panel {
  position: fixed; top: 0; right: 0; bottom: 0; z-index: 7600;
  width: min(360px, 90vw);
  background: rgba(2, 9, 18, 0.97); backdrop-filter: blur(30px);
  border-left: 1px solid var(--ov-border);
  display: flex; flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.5s var(--ov-ease);
  overflow-y: auto; overflow-x: hidden;
}
#vyr-panel.open { transform: translateX(0); }
.op-header {
  padding: 26px 26px 18px; border-bottom: 1px solid var(--ov-border);
  display: flex; align-items: flex-start; justify-content: space-between; gap: 14px;
  flex-shrink: 0;
}
.op-logo { font-family: 'Archivo Narrow', sans-serif; font-weight: 800; font-size: 1.05rem; letter-spacing: 0.14em; color: var(--glow); }
.op-sub { font-family: 'Courier Prime', monospace; font-size: 0.58rem; color: var(--t3); margin-top: 4px; letter-spacing: 0.08em; }
.op-close {
  width: 32px; height: 32px; border-radius: 50%;
  background: transparent; border: 1px solid var(--ov-border);
  color: var(--t2); font-size: 0.9rem;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; flex-shrink: 0;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.op-close:hover { background: rgba(0,212,255,0.08); border-color: rgba(0,212,255,0.3); color: var(--t1); }
.op-section { padding: 20px 26px; border-bottom: 1px solid var(--ov-border); }
.op-section:last-child { border-bottom: none; }
.op-label { font-family: 'Courier Prime', monospace; font-size: 0.56rem; letter-spacing: 0.2em; color: var(--t3); text-transform: uppercase; margin-bottom: 13px; }
.op-desc { font-family: 'Archivo', sans-serif; font-size: 0.82rem; color: var(--t2); line-height: 1.75; }
.op-desc strong { color: var(--t1); font-weight: 500; }
.op-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 9px; }
.op-stat { background: rgba(0,212,255,0.05); border: 1px solid rgba(0,212,255,0.12); border-radius: 8px; padding: 13px; text-align: center; }
.op-stat-num { font-family: 'Courier Prime', monospace; font-weight: 700; font-size: 1.2rem; color: var(--glow); line-height: 1; }
.op-stat-num.amber { color: var(--amber); }
.op-stat-lbl { font-family: 'Courier Prime', monospace; font-size: 0.54rem; color: var(--t3); margin-top: 5px; letter-spacing: 0.07em; text-transform: uppercase; }
.op-navlinks { display: flex; flex-direction: column; gap: 3px; }
.op-navlink {
  display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 6px;
  color: var(--t2); font-family: 'Archivo', sans-serif; font-size: 0.8rem;
  border: 1px solid transparent; cursor: pointer; text-decoration: none;
  transition: background 0.14s, border-color 0.14s, color 0.14s, transform 0.14s;
}
.op-navlink:hover { background: rgba(0,212,255,0.06); border-color: rgba(0,212,255,0.14); color: var(--t1); transform: translateX(3px); }
.op-navlink-arrow { margin-left: auto; font-size: 0.65rem; color: var(--t3); transition: transform 0.14s, color 0.14s; }
.op-navlink:hover .op-navlink-arrow { transform: translateX(3px); color: var(--glow); }
.op-cta-stack { display: flex; flex-direction: column; gap: 9px; }
.op-cta-primary {
  width: 100%; padding: 13px;
  background: linear-gradient(135deg, rgba(0,212,255,0.16), rgba(0,80,180,0.25));
  border: 1px solid rgba(0,212,255,0.45); border-radius: 4px; color: var(--glow);
  font-family: 'Courier Prime', monospace; font-size: 0.64rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer;
  box-shadow: 0 0 14px rgba(0,212,255,0.15);
  transition: background 0.18s, box-shadow 0.18s, transform 0.16s var(--ov-ease);
  text-decoration: none; display: block; text-align: center;
}
.op-cta-primary:hover { background: linear-gradient(135deg, rgba(0,212,255,0.24), rgba(0,80,180,0.36)); box-shadow: 0 0 26px rgba(0,212,255,0.3); transform: scale(1.02); }
.op-cta-ghost {
  width: 100%; padding: 12px; background: transparent;
  border: 1px solid rgba(0,212,255,0.18); border-radius: 4px; color: var(--t2);
  font-family: 'Courier Prime', monospace; font-size: 0.64rem; font-weight: 700;
  letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer;
  transition: border-color 0.18s, color 0.18s, transform 0.16s var(--ov-ease);
  text-decoration: none; display: block; text-align: center;
}
.op-cta-ghost:hover { border-color: rgba(0,212,255,0.38); color: var(--t1); transform: scale(1.02); }

/* ── 5. SCROLL NOTIFICATION ──────────────────────────────── */
#vyr-scroll-notif {
  position: fixed; top: 70px; left: 50%;
  transform: translateX(-50%) translateY(-90px);
  z-index: 8000;
  display: flex; align-items: center; gap: 9px; padding: 9px 18px;
  background: rgba(2, 9, 18, 0.93); backdrop-filter: blur(18px);
  border: 1px solid rgba(0,212,255,0.25); border-radius: 50px;
  box-shadow: 0 4px 22px rgba(0,0,0,0.45), 0 0 14px rgba(0,212,255,0.15);
  font-family: 'Courier Prime', monospace; font-size: 0.68rem;
  letter-spacing: 0.06em; color: var(--t2); white-space: nowrap;
  opacity: 0;
  transition: transform 0.5s var(--ov-ease), opacity 0.5s var(--ov-ease);
  pointer-events: none;
}
#vyr-scroll-notif.show { transform: translateX(-50%) translateY(0); opacity: 1; }
.osn-dot {
  width: 6px; height: 6px; border-radius: 50%; background: var(--glow);
  box-shadow: 0 0 7px var(--glow); flex-shrink: 0;
  animation: oSnDot 2s ease-in-out infinite;
}
@keyframes oSnDot { 0%,100%{opacity:1} 50%{opacity:0.25} }

/* ── MOBILE ADJUSTMENTS ──────────────────────────────────── */
@media (max-width: 480px) {
  .ov-inner { padding: 32px 22px; }
  .ov-actions { flex-direction: column; }
  .ov-actions .ov-btn-primary,
  .ov-actions .ov-btn-ghost { width: 100%; justify-content: center; }
  #vyr-install { left: 10px; right: 10px; bottom: 10px; max-width: 100%; }
  #vyr-orb { bottom: 18px; right: 18px; }
  .oo-tooltip { display: none; }
  #vyr-scroll-notif { font-size: 0.6rem; padding: 8px 14px; }
}

/* ── RESPONSIVE ──────────────────────────────────────────── */
@media(min-width:1280px){
  .nav,.live-banner,.page-header,.source-strip,.toolbar,.filter-bar,.method-section,.changelog-section,.footer{max-width:1440px;margin-left:auto;margin-right:auto}
}
@media(max-width:1100px){
  .nav-links{gap:1rem}
  .nav-links a{font-size:.6rem;letter-spacing:.11em}
  .company-grid{grid-template-columns:repeat(auto-fill,minmax(min(100%,340px),1fr))}
  .stack-grid{grid-template-columns:repeat(2,1fr)}
  .license-tiers{grid-template-columns:repeat(2,1fr)}
  .stress-grid{grid-template-columns:1fr}
  .boundary-split{grid-template-columns:1fr}
}
@media(max-width:900px){
  .nav-links{gap:.7rem}
  .nav-links a{font-size:.56rem;letter-spacing:.09em}
  .stack-grid{grid-template-columns:1fr}
  .license-tiers{grid-template-columns:1fr}
  .live-banner{flex-wrap:wrap}
  .lb-cell{min-width:50%;border-bottom:1px solid var(--border)}
  .source-strip{flex-wrap:wrap}
  .src-badge{min-width:50%}
}
@media(max-width:720px){
