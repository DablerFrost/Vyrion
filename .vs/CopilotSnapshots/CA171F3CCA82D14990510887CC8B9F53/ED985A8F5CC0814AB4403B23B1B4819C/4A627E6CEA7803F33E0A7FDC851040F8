function cdpCls(g){return g?g.startsWith('A')?'cdp-A':g.startsWith('B')?'cdp-B':g.startsWith('C')?'cdp-C':'cdp-D':'cdp-D'}
function imCls(g){return g?g.startsWith('A')?'im-A':g.startsWith('B')?'im-B':g.startsWith('C')?'im-C':'im-F':'im-F'}
function lawCls(n){return n===0?'law-0':n<=3?'law-low':n<=12?'law-mid':'law-high'}

function renderCard(co) {
  const bc = co.band==='breach'?'band-breach':co.band==='warning'?'band-warning':'band-track';
  const sbRows = co.sb.map(r=>`
    <div class="sb-row">
      <span class="sb-f">${r.f}</span>
      <span class="sb-w">${r.w}</span>
      <span class="sb-p">${r.p>0?'+':''}${r.p}</span>
    </div>`).join('');
  const total = co.sb.reduce((a,r)=>a+r.p,0);
  return `
<div class="c-card ${bc}" id="co-${co.id}" data-band="${co.band}" data-id="${co.id}" data-score="${co.score}" data-name="${co.name.toLowerCase()}" data-ticker="${co.ticker.toLowerCase()}" data-sabin="${co.sabin}">
