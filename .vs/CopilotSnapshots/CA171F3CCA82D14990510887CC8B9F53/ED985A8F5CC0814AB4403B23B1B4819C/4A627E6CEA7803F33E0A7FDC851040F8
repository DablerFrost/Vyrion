function getMag(el) {
  const key = el.dataset.mag;
  if (!key) return null;
  if (MAG[key]) return MAG[key];

  const card = el.closest('[data-id]');
  const co = card ? COMPANIES.find(c => c.id === card.dataset.id) : null;
  if (!co) return null;

  if (key==='score-bar') return {
    t:`${co.name} — CONSCIENCE Score: ${co.score}/100`,
    b:`Score computed from 4 factors: Pledge Quality (30 pts), CDP ${co.cdpYear} Performance (25 pts), InfluenceMap Lobbying Alignment (25 pts), Legal Exposure (20 pts). Band: ${co.bandLabel}. Threshold: Breach 0–30, Warning 31–60, On Track 61–100. Open the "Score calculation" dropdown below to see the full breakdown.`,
    s:`VYRION CONSCIENCE · CONSCIENCE-METHODOLOGY.md · Paris Agreement 1.5°C pathway basis`
  };
  if (key==='pledge-row') return {
    t:`Stated Pledge — ${co.name}`,
    b:`What ${co.name} has publicly committed to. Source: ${co.pledgeSrc}. CONSCIENCE assesses this pledge on four criteria: ambition level, scope coverage (1/2/3), deadline, and third-party validation (SBTi status). The pledge is scored against the Paris Agreement 1.5°C pathway — not the company's own baseline.`,
    s:co.pledgeSrc
  };
  if (key==='reality-row') return {
    t:`Verified Reality — ${co.name}`,
    b:`What the data actually shows about ${co.name}'s performance vs. their pledge. Sources cross-referenced: ${co.realitySrc}. CONSCIENCE compares company self-reporting against CDP independent responses, SEC regulatory filings, InfluenceMap lobbying analysis, and Sabin Center litigation records. The gap between pledge and reality is the core CONSCIENCE signal.`,
    s:co.realitySrc
  };
  if (key==='cdp-b') return {
    t:`CDP ${co.cdpYear} Grade — ${co.name}: ${co.cdpGrade}`,
    b:`CDP independently assessed ${co.name} as grade "${co.cdpGrade}". A = Leadership (best practice in governance, strategy, and disclosure — fewer than 2% of companies qualify). B = Management. C = Awareness. D = Disclosure only. CDP grades are independent — companies cannot influence their own grade through fees or advocacy.`,
    s:`CDP ${co.cdpYear} · cdp.net/en/responses · Independent assessment`
  };
  if (key==='im-b') return {
    t:`InfluenceMap Grade — ${co.name}: ${co.im}`,
    b:`InfluenceMap assessed ${co.name}'s climate policy engagement as "${co.im}". This reflects direct lobbying positions, trade association memberships, and policy interference. A–B = supportive. C–D = mixed or obstructive. F = actively lobbying against climate legislation. A company pledging net zero while funding obstruction of climate policy is a core CONSCIENCE accountability signal.`,
    s:`InfluenceMap · influencemap.org/company/${co.name.replace(/\s/g,'')} · Continuous`
  };
  if (key==='sbti-b') return {
    t:`SBTi Status — ${co.name}: ${co.sbti}`,
    b:`${co.name}'s SBTi status: "${co.sbti}". Approved 1.5°C = highest standard, requiring absolute reductions across all scopes aligned with 1.5°C science. Committed = target letter filed, not yet validated. Not committed = no SBTi engagement. SBTi status is a primary component of Pledge Quality scoring.`,
    s:`SBTi Registry · sciencebasedtargets.org/companies-taking-action`
  };
  if (key==='sabin-b') return {
    t:`Climate Lawsuits — ${co.name}: ${co.sabin} active`,
    b:`The Sabin Center lists ${co.sabin} active climate case${co.sabin!==1?'s':''} involving ${co.name}. CONSCIENCE applies −0.5 pts per active case (base 20 pts, floor 0). High lawsuit counts indicate pledge-vs-reality gaps that third parties — governments, NGOs, or citizens — have found legally actionable. Zero cases (as with Apple) reflects genuine legal alignment.`,
    s:`Sabin Center for Climate Change Law · climatecasechart.com · Columbia Law`
  };
  if (key==='tpi-b') return {
    t:`TPI Score — ${co.name}: ${co.tpi}`,
    b:`The Transition Pathway Initiative rated ${co.name} at ${co.tpi}. Level 1 = Unaware; 2 = Acknowledging; 3 = Developing; 4 = Integrated; 5 = Strategic. TPI is an independent corroboration of CONSCIENCE scoring — particularly for whether climate strategy is embedded in actual business decisions vs. surface communications.`,
    s:`TPI · transitionpathwayinitiative.org · London School of Economics`
  };
  if (key==='edgar-b') return {
    t:`SEC EDGAR — ${co.name} (CIK ${co.cik.replace(/^0+/,'')})`,
    b:`CONSCIENCE fetches ${co.name}'s latest 10-K or 20-F filing date from the SEC EDGAR submissions API in real-time. This verifies that climate disclosures cited in CONSCIENCE scores are cross-referenced against current regulatory filings — the same documents used by institutional investors and securities regulators.`,
    s:`SEC EDGAR · data.sec.gov/submissions/CIK${co.cik}.json · CORS-open public API`
  };
  return null;
}

