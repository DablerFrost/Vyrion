function updateStress() {
  const selected = Array.from(
    document.querySelectorAll('#stress-checkboxes input:checked')
  ).map(cb => STRESS_DATA.find(c => c.id === cb.dataset.id)).filter(Boolean);

  if (selected.length === 0) {
    document.getElementById('st-avg').textContent = '—';
    document.getElementById('st-band').textContent = '—';
    document.getElementById('st-lawsuits').textContent = '—';
    document.getElementById('st-breach-pct').textContent = '—';
    document.getElementById('st-track-pct').textContent = '—';
    document.getElementById('st-sbti').textContent = '—';
    ['breach','warn','track'].forEach(b => {
      document.getElementById('st-bar-'+b).style.width = '0%';
      document.getElementById('st-bar-'+b+'-pct').textContent = '0%';
    });
    return;
  }

  const n = selected.length;
  const avg = Math.round(selected.reduce((a,c) => a+c.score, 0) / n);
  const lawsuits = selected.reduce((a,c) => a+c.sabin, 0);
  const breachN = selected.filter(c => c.band==='breach').length;
  const warnN   = selected.filter(c => c.band==='warning').length;
  const trackN  = selected.filter(c => c.band==='track').length;
  const sbtiN   = selected.filter(c => c.sbti).length;

  const breachPct = Math.round((breachN/n)*100);
  const warnPct  = Math.round((warnN/n)*100);
  const trackPct = Math.round((trackN/n)*100);

  const band = avg <= 30 ? 'BREACH' : avg <= 60 ? 'WARNING' : 'ON TRACK';
  const bandCls = avg <= 30 ? 'sm-breach' : avg <= 60 ? 'sm-warn' : 'sm-track';
  const avgColor = avg <= 30 ? 'var(--breach)' : avg <= 60 ? 'var(--warn)' : 'var(--glow)';

  document.getElementById('st-avg').textContent = avg + ' / 100';
  document.getElementById('st-avg').style.color = avgColor;
  const bandEl = document.getElementById('st-band');
  bandEl.textContent = band + ' (' + n + ' cos.)';
  bandEl.className = 'sm-value ' + bandCls;
  document.getElementById('st-lawsuits').textContent = lawsuits;
  document.getElementById('st-lawsuits').className = 'sm-value ' + (lawsuits > 10 ? 'sm-breach' : lawsuits > 2 ? 'sm-warn' : 'sm-track');
  document.getElementById('st-breach-pct').textContent = breachPct + '%';
  document.getElementById('st-breach-pct').className = 'sm-value ' + (breachPct > 50 ? 'sm-breach' : 'sm-warn');
  document.getElementById('st-track-pct').textContent = trackPct + '%';
  document.getElementById('st-sbti').textContent = sbtiN + ' / ' + n + ' companies';

  document.getElementById('st-bar-breach').style.width = breachPct + '%';
  document.getElementById('st-bar-warn').style.width   = warnPct + '%';
  document.getElementById('st-bar-track').style.width  = trackPct + '%';
  document.getElementById('st-bar-breach-pct').textContent = breachPct + '%';
  document.getElementById('st-bar-warn-pct').textContent   = warnPct + '%';
  document.getElementById('st-bar-track-pct').textContent  = trackPct + '%';
}

