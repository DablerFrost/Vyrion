        <circle class="ring-fill" cx="36" cy="36" r="30"
          stroke-dasharray="188.5"
          stroke-dashoffset="188.5"
          data-filled="${(188.5*(1-co.score/100)).toFixed(1)}"/>
      </svg>
      <div class="ring-inner">
